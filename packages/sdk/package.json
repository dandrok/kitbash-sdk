{
  "name": "@ktbsh/sdk",
  "version": "0.2.0",
  "type": "module",
  "engines": {
    "bun": ">=1.0.0"
  },
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "bin": {
    "kitbash": "dist/cli.js"
  },
  "description": "Compiler-driven toolkit for building design-system components as Web Components (with React wrappers).",
  "keywords": [
    "kitbash",
    "design-system",
    "web-components",
    "custom-elements",
    "shadow-dom",
    "compiler",
    "bun",
    "react",
    "react-wrapper",
    "uhtml",
    "form-associated",
    "theming",
    "css-parts",
    "design-tokens",
    "component-library",
    "cli",
    "typescript",
    "framework-agnostic"
  ],
  "homepage": "https://github.com/dandrok/kitbash-sdk/tree/main/packages/sdk#readme",
  "bugs": {
    "url": "https://github.com/dandrok/kitbash-sdk/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/dandrok/kitbash-sdk.git",
    "directory": "packages/sdk"
  },
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "dist",
    "templates",
    "src"
  ],
  "dependencies": {
    "uhtml": "4.7.1"
  },
  "devDependencies": {
    "@playwright/test": "1.52.0",
    "bun-types": "1.3.14",
    "happy-dom": "20"
  },
  "scripts": {
    "build": "bun run scripts/build.ts && bun build ./src/cli.ts --outfile ./dist/cli.js --target bun",
    "test": "bun test src",
    "test:browser:prepare": "bun run e2e/prepare.ts",
    "test:browser": "bun run test:browser:prepare && bun test e2e/browser-runtime.bun.test.ts",
    "test:all": "bun run test && bun run test:browser"
  }
}
