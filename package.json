{
  "name": "kitbash-workspace",
  "version": "0.0.0",
  "private": true,
  "scripts": {
    "dev": "bun run scripts/dev.ts",
    "format": "bunx @biomejs/biome format --write .",
    "lint": "bunx @biomejs/biome lint .",
    "check": "bunx @biomejs/biome check --write .",
    "ci": "bunx @biomejs/biome ci .",
    "build:sdk": "bun run --cwd packages/sdk build",
    "smoke": "bun run scripts/ci-smoke.ts",
    "test:sdk": "bun run --cwd packages/sdk test",
    "test": "bun run test:sdk && bun run smoke"
  },
  "devDependencies": {
    "@biomejs/biome": "2.5.4"
  },
  "workspaces": [
    "packages/*",
    "templates/*",
    "sandbox"
  ]
}
